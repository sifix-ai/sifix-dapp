# ============================================
# DATABASE - Supabase (postgres database)
# Get these from: https://supabase.com/dashboard/project/_/settings/database
# ============================================
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres"

# ============================================
# BLOCKCHAIN
# Get your Alchemy API key from: https://dashboard.alchemy.com/
# ============================================
NEXT_PUBLIC_BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY"
NEXT_PUBLIC_BASESCAN_URL="https://sepolia.basescan.org"
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY"

# Smart Contracts
NEXT_PUBLIC_SCAM_REPORTER_BASE_SEPOLIA_ADDRESS="0x..."  # Base Sepolia (testnet)
# NEXT_PUBLIC_SCAM_REPORTER_BASE_ADDRESS="0x..."        # Base mainnet (belum deploy)

# Backend wallet (SERVER-SIDE ONLY — never expose client-side)
# WALLET_PRIVATE_KEY="0x..."

# ============================================
# EXTERNAL APIS
# ============================================
DEFILLAMA_API_URL="https://api.llama.fi"
SCAMSNIFFER_REPO_URL="https://github.com/scamsniffer/scam-database"
CRYPTOSCAMDB_API_URL="https://cryptoscamdb.org/api"

# ============================================
# RATE LIMITING (optional — Upstash Redis)
# Get from: https://console.upstash.com/
# ============================================
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Generate a strong random secret: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"
NODE_ENV="development"
