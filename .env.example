# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database (PostgreSQL)
# DEVELOPMENT: Use local PostgreSQL or SQLite
# DATABASE_URL="file:./dev.db"  # SQLite (development only)
DATABASE_URL="postgresql://sifix:CHANGE_ME@127.0.0.1:5432/sifix?schema=public"

# PRODUCTION (Vercel): Use managed PostgreSQL service
# Recommended providers:
# - Neon: https://neon.tech (Free tier, serverless)
# - Supabase: https://supabase.com (Free tier with dashboard)
# - Railway: https://railway.app (Free $5 credit/month)
# - Vercel Postgres: https://vercel.com/storage/postgres (Paid)
#
# Example production URL:
# DATABASE_URL="postgresql://user:password@host.region.provider.com:5432/database?sslmode=require"

# ============================================
# WEB3 CONFIGURATION
# ============================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# 0G Chain Configuration
NEXT_PUBLIC_ZG_RPC_URL="https://evmrpc-testnet.0g.ai"
NEXT_PUBLIC_ZG_CHAIN_ID="16602"

# Contract Addresses
NEXT_PUBLIC_SIFIX_CONTRACT=""
NEXT_PUBLIC_FLOW_CONTRACT=""

# ============================================
# AI CONFIGURATION
# ============================================

# AI Provider (fallback when 0G Compute not configured)
# For OpenAI:
AI_API_KEY=""  # sk-...
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4-turbo-preview"

# For other providers (Anthropic, etc):
# AI_BASE_URL="https://api.anthropic.com/v1"
# AI_MODEL="claude-3-opus-20240229"

# ============================================
# 0G STORAGE CONFIGURATION
# ============================================

# 0G Storage (server-side wallet for uploads)
ZG_INDEXER_URL="https://indexer-storage-testnet-turbo.0g.ai"
STORAGE_PRIVATE_KEY=""  # Private key for storage uploads (NEVER commit this!)
STORAGE_MOCK_MODE="true"  # Set to "false" in production

# ============================================
# 0G COMPUTE CONFIGURATION
# ============================================

# 0G Compute (decentralized AI inference)
# Setup steps:
# 1. Install: npm install -g @0glabs/0g-compute-cli
# 2. List providers: 0g-compute-cli inference list-providers
# 3. Deposit: 0g-compute-cli deposit --amount 10
# 4. Transfer: 0g-compute-cli transfer-fund --provider <ADDRESS> --amount 5
# 5. Fill COMPUTE_PROVIDER_ADDRESS below

COMPUTE_PRIVATE_KEY=""  # Private key for compute (NEVER commit this!)
COMPUTE_PROVIDER_ADDRESS=""  # Provider address from step 2

# ============================================
# 0G AGENTIC ID CONFIGURATION (ERC-7857)
# ============================================

# Agentic ID Contract (official contract on 0G Galileo testnet)
NEXT_PUBLIC_AGENTIC_ID_CONTRACT_ADDRESS="0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F"

# Agentic ID Token ID (set after minting)
# Leave empty to disable Agentic ID guard
NEXT_PUBLIC_AGENTIC_ID_TOKEN_ID=""

# ============================================
# APP CONFIGURATION
# ============================================

# App URL (for production deployment)
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # Change to your Vercel URL in production
NEXT_PUBLIC_APP_NAME="SIFIX"

# Node Environment (auto-set by Vercel)
NODE_ENV="development"  # "production" in Vercel

# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================
#
# Required environment variables for Vercel:
# 1. DATABASE_URL (MUST be PostgreSQL, not SQLite)
# 2. AI_API_KEY (for threat analysis)
# 3. STORAGE_PRIVATE_KEY (for 0G Storage uploads)
# 4. NEXT_PUBLIC_* variables (for client-side access)
#
# Optional but recommended:
# - COMPUTE_PRIVATE_KEY + COMPUTE_PROVIDER_ADDRESS (for 0G Compute)
# - NEXT_PUBLIC_AGENTIC_ID_TOKEN_ID (for Agentic ID guard)
#
# See VERCEL_SETUP.md for detailed deployment guide
#
