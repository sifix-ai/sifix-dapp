# Database (SQLite)
DATABASE_URL="file:./dev.db"

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# 0G Chain
NEXT_PUBLIC_ZG_RPC_URL="https://evmrpc-testnet.0g.ai"
NEXT_PUBLIC_ZG_CHAIN_ID="16602"

# Contract Addresses
NEXT_PUBLIC_SIFIX_CONTRACT=""
NEXT_PUBLIC_FLOW_CONTRACT=""

# AI Provider (fallback when 0G Compute not configured)
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL=""

# 0G Storage (server-side wallet for uploads)
ZG_INDEXER_URL="https://indexer-storage-testnet-turbo.0g.ai"
STORAGE_PRIVATE_KEY=""
STORAGE_MOCK_MODE="true"

# 0G Compute (decentralized AI inference)
# Step 1: 0g-compute-cli inference list-providers
# Step 2: 0g-compute-cli deposit --amount 10
# Step 3: 0g-compute-cli transfer-fund --provider <ADDRESS> --amount 5
# Step 4: Fill COMPUTE_PROVIDER_ADDRESS below
COMPUTE_PRIVATE_KEY=""
COMPUTE_PROVIDER_ADDRESS=""

# 0G Agentic ID (ERC-7857)
# Contract: official Agentic ID contract on 0G Galileo testnet
NEXT_PUBLIC_AGENTIC_ID_CONTRACT_ADDRESS="0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F"
# Set token ID after minting. Leave empty to disable Agentic ID guard.
NEXT_PUBLIC_AGENTIC_ID_TOKEN_ID=""
