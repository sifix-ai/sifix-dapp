generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AddressTag {
  id        String    @id @default(cuid())
  addressId String
  tag       String
  taggedBy  String?
  upvotes   Int       @default(0)
  downvotes Int       @default(0)
  createdAt DateTime  @default(now())
  address    Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([addressId, tag])
  @@index([addressId])
  @@index([tag])
  @@index([taggedBy])
  @@map("address_tags")
}

model Address {
  id                String              @id @default(cuid())
  address           String              @unique
  chain             String              @default("0g-galileo")
  addressType       String              @default("EOA")
  riskScore         Int                 @default(0)
  riskLevel         String              @default("LOW")
  totalReports      Int                 @default(0)
  firstSeenAt       DateTime            @default(now())
  lastSeenAt        DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime @updatedAt
  tags       AddressTag[]
  reputation ReputationScore?
  reports          ThreatReport[]
  scans      TransactionScan[]

  @@index([chain])
  @@index([riskLevel])
  @@index([riskScore])

  @@map("addresses")
}

model ExtensionSession {
  id            String   @id @default(cuid())
  walletAddress String
  token         String   @unique
  userAgent     String?
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([token])
  @@index([walletAddress])

  @@map("extension_sessions")
}

model PredictionAccuracy {
  id                      String    @id @default(cuid())
  targetAddress           String
  analysisType            String
  predictedRiskScore      Int
  predictedRiskLevel      String
  predictedConfidence     Int
  predictedRecommendation String
  predictedThreats        String?
  provider                String    @default("default")
  actualOutcome           String?
  isCorrect               Boolean?
  groundTruthSource       String?
  goPlusRiskScore         Int?
  communityRiskLevel      String?
  resolvedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([analysisType])
  @@index([createdAt])
  @@index([isCorrect])
  @@index([predictedRiskLevel])
  @@index([provider])
  @@index([targetAddress])

  @@map("prediction_accuracy")
}

model ReportVote {
  id             String         @id @default(cuid())
  reportId       String
  voterAddress   String
  voteType       String
  weight         Int            @default(1)
  reason         String?
  createdAt      DateTime       @default(now())
  report     ThreatReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, voterAddress])
  @@index([reportId])
  @@index([voterAddress])

  @@map("report_votes")
}

model ReputationScore {
  id                String    @id @default(cuid())
  addressId         String    @unique
  overallScore      Int       @default(0)
  reporterScore     Int       @default(0)
  accuracyScore     Int       @default(0)
  reportsSubmitted  Int       @default(0)
  reportsVerified   Int       @default(0)
  reportsRejected   Int       @default(0)
  onchainReputation Int?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt
  address         Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([overallScore])
  @@index([reporterScore])

  @@map("reputation_scores")
}

model ScamDomain {
  id          String   @id @default(cuid())
  domain      String   @unique
  riskScore   Int      @default(80)
  category    String   @default("PHISHING")
  description String?
  source      String   @default("COMMUNITY")
  reportedBy  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([domain])
  @@index([isActive])

  @@map("scam_domains")
}

model ScanHistory {
  id              String   @id @default(cuid())
  fromAddress     String
  toAddress       String
  riskScore       Int
  riskLevel       String
  recommendation  String
  reasoning       String?
  threats         String?
  confidence      Float    @default(0)
  rootHash        String?
  storageExplorer String?
  analyzedAt      DateTime @default(now())

  @@index([analyzedAt])
  @@index([fromAddress])
  @@index([riskLevel])
  @@index([toAddress])

  @@map("scan_history")
}

model SearchHistory {
  id          String   @id @default(cuid())
  userAddress String?
  searchType  String
  query       String
  riskScore   Int      @default(0)
  riskLevel   String   @default("LOW")
  result      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userAddress])

  @@map("search_history")
}

model SyncLog {
  id             String    @id @default(cuid())
  source         String
  status         String
  recordsAdded   Int       @default(0)
  recordsUpdated Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([source])
  @@index([startedAt])

  @@map("sync_logs")
}

model SyncState {
  id           String   @id @default(cuid())
  name         String   @unique
  lastBlock    Int      @default(0)
  chainId      Int
  source       String   @default("onchain")
  status       String   @default("active")
  lastSyncAt   DateTime @default(now())
  errorMessage String?
  metadata     String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([chainId])
  @@index([name])
  @@index([status])

  @@map("sync_state")
}

model ThreatReport {
  id              String         @id @default(cuid())
  addressId       String
  reporterAddress String
  threatType      String
  severity        Int
  riskLevel       String
  evidenceHash    String
  explanation     String
  transactionHash String?
  aiModel         String         @default("gpt-4")
  confidence      Int
  simulationData  String?
  status          String         @default("PENDING")
  localStatus     String         @default("PENDING_LOCAL")
  onchainStatus   String         @default("NONE")
  verifiedBy      String?
  verifiedAt      DateTime?
  reportHash      String?
  onchainTxHash   String?
  blockNumber     Int?
  chainId         Int?
  contractAddress String?
  relayError      String?
  relayAttempts   Int            @default(0)
  nextRelayAt     DateTime?
  relayedAt       DateTime?
  deadLetter      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime @updatedAt
  votes           ReportVote[]
  address         Address      @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([addressId, status])
  @@index([createdAt])
  @@index([localStatus])
  @@index([onchainStatus])
  @@index([reporterAddress, createdAt])
  @@index([reporterAddress])
  @@index([riskLevel])
  @@index([riskLevel, status])
  @@index([status])
  @@index([threatType])

  @@map("threat_reports")
}

model TransactionScan {
  id                String    @id @default(cuid())
  addressId         String
  from              String
  to                String
  value             BigInt?
  data              String?
  simulationSuccess Boolean
  gasUsed           BigInt?
  stateChanges      String?
  riskScore         Int
  riskLevel         String
  recommendation    String
  explanation       String
  detectedThreats   String?
  scanDuration      Int?
  agentVersion      String    @default("1.0.0")
  createdAt         DateTime  @default(now())
  address         Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([addressId, riskLevel])
  @@index([createdAt])
  @@index([from, createdAt])
  @@index([from])
  @@index([riskLevel])

  @@map("transaction_scans")
}

model UserProfile {
  id               String   @id @default(cuid())
  address          String   @unique
  scansPerformed   Int      @default(0)
  threatsDetected  Int      @default(0)
  reportsSubmitted Int      @default(0)
  autoReport       Boolean  @default(false)
  notifyOnThreat   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user_profiles")
}

model UserSettings {
  id         String   @id @default(cuid())
  address    String   @unique
  aiProvider String   @default("default")
  aiApiKey   String?
  aiBaseUrl  String?
  aiModel    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([address])

  @@map("user_settings")
}

model Watchlist {
  id             String   @id @default(cuid())
  userAddress    String
  watchedAddress String
  label          String?
  lastScore      Int      @default(0)
  prevScore      Int      @default(0)
  alertOnChange  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userAddress, watchedAddress])
  @@index([userAddress])
  @@index([watchedAddress])

  @@map("watchlist")
}

model ProtocolApplication {
  id            String   @id @default(cuid())
  protocolName  String
  website       String
  contactEmail  String
  useCase       String
  requestedTier String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])

  @@map("protocol_applications")
}

