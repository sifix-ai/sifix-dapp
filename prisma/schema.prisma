generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model address_tags {
  id        String    @id
  addressId String
  tag       String
  taggedBy  String?
  upvotes   Int       @default(0)
  downvotes Int       @default(0)
  createdAt DateTime  @default(now())
  addresses addresses @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([addressId, tag])
  @@index([addressId])
  @@index([tag])
  @@index([taggedBy])
}

model addresses {
  id                String              @id
  address           String              @unique
  chain             String              @default("0g-galileo")
  addressType       String              @default("EOA")
  riskScore         Int                 @default(0)
  riskLevel         String              @default("LOW")
  totalReports      Int                 @default(0)
  firstSeenAt       DateTime            @default(now())
  lastSeenAt        DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  address_tags      address_tags[]
  reputation_scores reputation_scores?
  threat_reports    threat_reports[]
  transaction_scans transaction_scans[]

  @@index([chain])
  @@index([riskLevel])
  @@index([riskScore])
}

model extension_sessions {
  id            String   @id
  walletAddress String
  token         String   @unique
  userAgent     String?
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([token])
  @@index([walletAddress])
}

model prediction_accuracy {
  id                      String    @id
  targetAddress           String
  analysisType            String
  predictedRiskScore      Int
  predictedRiskLevel      String
  predictedConfidence     Int
  predictedRecommendation String
  predictedThreats        String?
  provider                String    @default("default")
  actualOutcome           String?
  isCorrect               Boolean?
  groundTruthSource       String?
  goPlusRiskScore         Int?
  communityRiskLevel      String?
  resolvedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime

  @@index([analysisType])
  @@index([createdAt])
  @@index([isCorrect])
  @@index([predictedRiskLevel])
  @@index([provider])
  @@index([targetAddress])
}

model report_votes {
  id             String         @id
  reportId       String
  voterAddress   String
  voteType       String
  weight         Int            @default(1)
  reason         String?
  createdAt      DateTime       @default(now())
  threat_reports threat_reports @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, voterAddress])
  @@index([reportId])
  @@index([voterAddress])
}

model reputation_scores {
  id                String    @id
  addressId         String    @unique
  overallScore      Int       @default(0)
  reporterScore     Int       @default(0)
  accuracyScore     Int       @default(0)
  reportsSubmitted  Int       @default(0)
  reportsVerified   Int       @default(0)
  reportsRejected   Int       @default(0)
  onchainReputation Int?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  addresses         addresses @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([overallScore])
  @@index([reporterScore])
}

model scam_domains {
  id          String   @id
  domain      String   @unique
  riskScore   Int      @default(80)
  category    String   @default("PHISHING")
  description String?
  source      String   @default("COMMUNITY")
  reportedBy  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([category])
  @@index([domain])
  @@index([isActive])
}

model scan_history {
  id              String   @id
  fromAddress     String
  toAddress       String
  riskScore       Int
  riskLevel       String
  recommendation  String
  reasoning       String?
  threats         String?
  confidence      Float    @default(0)
  rootHash        String?
  storageExplorer String?
  analyzedAt      DateTime @default(now())

  @@index([analyzedAt])
  @@index([fromAddress])
  @@index([riskLevel])
  @@index([toAddress])
}

model search_history {
  id          String   @id
  userAddress String?
  searchType  String
  query       String
  riskScore   Int      @default(0)
  riskLevel   String   @default("LOW")
  result      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userAddress])
}

model sync_logs {
  id             String    @id
  source         String
  status         String
  recordsAdded   Int       @default(0)
  recordsUpdated Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([source])
  @@index([startedAt])
}

model sync_state {
  id           String   @id
  name         String   @unique
  lastBlock    Int      @default(0)
  chainId      Int
  source       String   @default("onchain")
  status       String   @default("active")
  lastSyncAt   DateTime @default(now())
  errorMessage String?
  metadata     String?
  updatedAt    DateTime
  createdAt    DateTime @default(now())

  @@index([chainId])
  @@index([name])
  @@index([status])
}

model threat_reports {
  id              String         @id
  addressId       String
  reporterAddress String
  threatType      String
  severity        Int
  riskLevel       String
  evidenceHash    String
  explanation     String
  transactionHash String?
  aiModel         String         @default("gpt-4")
  confidence      Int
  simulationData  String?
  status          String         @default("PENDING")
  localStatus     String         @default("PENDING_LOCAL")
  onchainStatus   String         @default("NONE")
  verifiedBy      String?
  verifiedAt      DateTime?
  reportHash      String?
  onchainTxHash   String?
  blockNumber     Int?
  chainId         Int?
  contractAddress String?
  relayError      String?
  relayAttempts   Int            @default(0)
  nextRelayAt     DateTime?
  relayedAt       DateTime?
  deadLetter      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  report_votes    report_votes[]
  addresses       addresses      @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([addressId, status])
  @@index([createdAt])
  @@index([localStatus])
  @@index([onchainStatus])
  @@index([reporterAddress, createdAt])
  @@index([reporterAddress])
  @@index([riskLevel])
  @@index([riskLevel, status])
  @@index([status])
  @@index([threatType])
}

model transaction_scans {
  id                String    @id
  addressId         String
  from              String
  to                String
  value             BigInt?
  data              String?
  simulationSuccess Boolean
  gasUsed           BigInt?
  stateChanges      String?
  riskScore         Int
  riskLevel         String
  recommendation    String
  explanation       String
  detectedThreats   String?
  scanDuration      Int?
  agentVersion      String    @default("1.0.0")
  createdAt         DateTime  @default(now())
  addresses         addresses @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([addressId, riskLevel])
  @@index([createdAt])
  @@index([from, createdAt])
  @@index([from])
  @@index([riskLevel])
}

model user_profiles {
  id               String   @id
  address          String   @unique
  scansPerformed   Int      @default(0)
  threatsDetected  Int      @default(0)
  reportsSubmitted Int      @default(0)
  autoReport       Boolean  @default(false)
  notifyOnThreat   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model user_settings {
  id         String   @id
  address    String   @unique
  aiProvider String   @default("default")
  aiApiKey   String?
  aiBaseUrl  String?
  aiModel    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([address])
}

model watchlist {
  id             String   @id
  userAddress    String
  watchedAddress String
  label          String?
  lastScore      Int      @default(0)
  prevScore      Int      @default(0)
  alertOnChange  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@unique([userAddress, watchedAddress])
  @@index([userAddress])
  @@index([watchedAddress])
}

model protocol_applications {
  id            String   @id @default(cuid())
  protocolName  String
  website       String
  contactEmail  String
  useCase       String
  requestedTier String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
