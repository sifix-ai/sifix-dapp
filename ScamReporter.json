    "rawMetadata": "{\"compiler\":{\"version\":\"0.8.24+commit.e11b9ed9\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"targetId\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"reporter\",\"type\":\"address\"}],\"name\":\"AlreadyVoted\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"EmptyReasonHash\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"EmptyTargetId\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"InvalidTargetType\",\"type\":\"error\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"reporter\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"ScamReportSubmitted\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"reporter\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"targetId\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"uint8\",\"name\":\"targetType\",\"type\":\"uint8\"},{\"indexed\":false,\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"ScamVoteSubmitted\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"target\",\"type\":\"address\"}],\"name\":\"addressToTargetId\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"pure\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"targetId\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"reporterAddr\",\"type\":\"address\"}],\"name\":\"hasVoted\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"submitReport\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint8\",\"name\":\"targetType\",\"type\":\"uint8\"},{\"internalType\":\"bytes32\",\"name\":\"targetId\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"submitVote\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Minimal on-chain state: only anti-double-vote tracking keyed by         (targetId, reporter). Payload strings stay off-chain and are         represented by hashes for gas-efficient, indexer-friendly logs.         The reasonHash must be the keccak256 of the off-chain payload so the         Supabase listener can verify on-chain \\u2194 off-chain consistency.\",\"errors\":{\"AlreadyVoted(bytes32,address)\":[{\"details\":\"Reverts when `reporter` already voted for `targetId`.\"}],\"EmptyReasonHash()\":[{\"details\":\"Reverts when `reasonHash` is the zero value, which would make the      event unverifiable against any real off-chain record.\"}],\"EmptyTargetId()\":[{\"details\":\"Reverts when `targetId` is zero.\"}],\"InvalidTargetType()\":[{\"details\":\"Reverts when `targetType` is outside [0..2].\"}]},\"events\":{\"ScamReportSubmitted(address,bytes32,bool)\":{\"params\":{\"isScam\":\"True = reporter believes target is a scam.                   Non-indexed (boolean, low cardinality \\u2014 not useful as a                   filter topic, saves one topic slot per log entry).\",\"reasonHash\":\"keccak256 of the off-chain reason payload (indexed for                   integrity checks \\u2014 fetch the hash, verify the payload).\",\"reporter\":\"Address that submitted the report (indexed for                   per-address lookups in the off-chain indexer).\"}},\"ScamVoteSubmitted(address,bytes32,uint8,bytes32,bool)\":{\"params\":{\"isScam\":\"True = reporter believes target is a scam.\",\"reasonHash\":\"keccak256 of off-chain reason payload.\",\"reporter\":\"Address that submitted the vote (indexed).\",\"targetId\":\"Normalized target identifier hash (indexed).\",\"targetType\":\"0=ADDRESS, 1=ENS, 2=DOMAIN.\"}}},\"kind\":\"dev\",\"methods\":{\"submitReport(bytes32,bool)\":{\"details\":\"Deprecated: this legacy method is target-agnostic and does not         include a target identifier, so indexers cannot map the vote to         a specific target directly from logs.\",\"params\":{\"isScam\":\"True if the reporter considers the target a scam.\",\"reasonHash\":\"keccak256 of the off-chain reason payload.                    Must not be bytes32(0).\"}},\"submitVote(uint8,bytes32,bytes32,bool)\":{\"params\":{\"isScam\":\"True if the reporter considers the target a scam.\",\"reasonHash\":\"keccak256 of off-chain reason payload. Must not be zero.\",\"targetId\":\"Normalized target identifier hash. Must not be zero.\",\"targetType\":\"0=ADDRESS, 1=ENS, 2=DOMAIN.\"}}},\"stateVariables\":{\"hasVotedByTarget\":{\"details\":\"targetId => reporter => has voted\"}},\"title\":\"ScamReporter\",\"version\":1},\"userdoc\":{\"events\":{\"ScamReportSubmitted(address,bytes32,bool)\":{\"notice\":\"Emitted for every scam-report vote.\"},\"ScamVoteSubmitted(address,bytes32,uint8,bytes32,bool)\":{\"notice\":\"Emitted for every target-based scam vote (primary event for         indexers such as Ponder).\"}},\"kind\":\"user\",\"methods\":{\"addressToTargetId(address)\":{\"notice\":\"Converts an address target to normalized bytes32 targetId.\"},\"hasVoted(bytes32,address)\":{\"notice\":\"Returns whether `reporter` has already voted for `targetId`.\"},\"submitReport(bytes32,bool)\":{\"notice\":\"Submit a scam-report vote.\"},\"submitVote(uint8,bytes32,bytes32,bool)\":{\"notice\":\"Submit a target-scoped scam vote.\"}},\"notice\":\"Decentralized scam-report vote submission for the Wallo platform.         All data lives off-chain (Supabase); this contract is the integrity         anchor \\u2014 it proves a given (reporter, reasonHash, isScam) triple was         witnessed by the chain at a specific block.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/ScamReporter.sol\":\"ScamReporter\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"]},\"sources\":{\"src/ScamReporter.sol\":{\"keccak256\":\"0x62129036f589751d1b1ad1a0b2ade15cd0d7d5441b0c86426c026f9fd98e47f5\",\"license\":\"UNLICENSED\",\"urls\":[\"bzz-raw://0a9ff1a7944f0eb88c88963fed73329743b44d66cb51e8bad1e4a2de1e46d6fc\",\"dweb:/ipfs/QmNsoeGJUjSfDAodPNmBpeGJZwvTXbNFrLNAYeM72iymvn\"]}},\"version\":1}",
